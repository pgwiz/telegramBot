{
  "name": "telegramBot · Python 3.12",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md", "src/bot.py"]
    },
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.extraPaths": ["src"],
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"]
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ]
    }
  },
  "updateContentCommand": "pip3 install --user -r requirements-dev.txt && echo '✅ Dependencies installed'",
  "postAttachCommand": "echo 'Run: cp .env.example .env  →  edit  →  make run'"
}

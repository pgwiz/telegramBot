# --- Telegram ---
TELEGRAM_BOT_TOKEN=put-your-token-from-@BotFather-here
BOT_OWNER_ID=123456789                  # numeric Telegram user id of the owner
TELEGRAM_ACTION_GROUP_ID=-100xxxxxxxxxx # group that receives renewal/feedback pings
TELEGRAM_NORMAL_GROUP_ID=-100xxxxxxxxxx # optional broadcast group

# --- Database ---
DATABASE_URL=sqlite:///bot.db

# --- Personality ---
DEFAULT_VIBE=funny                      # funny | pro | chill
LLM_PROVIDER=                           # "" disables LLM, "openai" or "groq" enables it
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=                           # optional (e.g. https://api.groq.com/openai/v1)

# --- Autonomy ---
ENABLE_SCHEDULER=true
HEARTBEAT_CRON=0 9 * * *                # daily 09:00 UTC ping to owner
DAILY_FACT_CHANNEL=                     # chat id; leave empty to disable
DAILY_FACT_CRON=0 12 * * *

# --- Robustness ---
LOG_LEVEL=INFO
LOG_JSON=false
HTTP_TIMEOUT=15
RETRY_MAX_ATTEMPTS=5
RETRY_BACKOFF_BASE=1.5

# --- Integrations (all optional) ---
OPENWEATHER_API_KEY=                    # falls back to Open-Meteo if blank
COINGECKO_BASE=https://api.coingecko.com/api/v3
